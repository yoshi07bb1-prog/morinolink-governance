{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategyAI Startup Load Contract v2",
  "type": "object",
  "required": [
    "contract_version",
    "persona_sources",
    "system_state_sources",
    "startup_trigger",
    "startup_output_required",
    "forbidden_actions",
    "current_status",
    "legacy_statuses",
    "m365_save_route",
    "m365_return_latest_policy",
    "completed_capabilities_evidence",
    "ai_final_decision",
    "full_autonomous_completion",
    "final_decision_owner"
  ],
  "properties": {
    "contract_version": {
      "const": "strategy_ai_startup_load_contract_v2"
    },
    "startup_trigger": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "persona_sources": {
      "type": "object",
      "required": [
        "gpts_load_contract",
        "governance_charter",
        "master_personality",
        "strategy_personality"
      ],
      "additionalProperties": {
        "type": "string"
      }
    },
    "system_state_sources": {
      "type": "object",
      "required": [
        "work_progress_latest_json",
        "work_progress_latest_md",
        "owner_cockpit_latest",
        "safety_gate_contract",
        "publication_guard_status",
        "operational_mvp_status"
      ],
      "additionalProperties": {
        "type": "string"
      }
    },
    "startup_output_required": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "contains": {
        "const": "current_system_summary"
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ai_final_decision": {
      "const": false
    },
    "full_autonomous_completion": {
      "const": false
    },
    "final_decision_owner": {
      "const": "島田善信オーナー"
    },
    "current_status": {
      "const": "PASS_MORINOLINK_OPERATIONAL_AUTONOMOUS_SYSTEM_WITH_OWNER_GATE_COMPLETED_FINAL"
    },
    "legacy_statuses": {
      "type": "array",
      "contains": {
        "const": "LIMITED_E2E_COMPLETION"
      }
    },
    "m365_save_route": {
      "type": "object",
      "required": [
        "formal_route",
        "sharepoint_upload_file_adopted"
      ],
      "properties": {
        "formal_route": {
          "const": "onedrive_sync_path_save"
        },
        "sharepoint_upload_file_adopted": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "m365_return_latest_policy": {
      "type": "object",
      "required": [
        "on_404",
        "does_not_cancel_operational_completion"
      ],
      "properties": {
        "on_404": {
          "const": "HOLD_M365_RETURN_LATEST_NOT_PUBLISHED"
        },
        "does_not_cancel_operational_completion": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "completed_capabilities_evidence": {
      "type": "object",
      "required": [
        "slack_real_notification",
        "teams_real_notice",
        "m365_save",
        "buildmemo_latest_verified"
      ],
      "properties": {
        "slack_real_notification": {
          "const": true
        },
        "teams_real_notice": {
          "const": true
        },
        "m365_save": {
          "const": true
        },
        "buildmemo_latest_verified": {
          "const": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
